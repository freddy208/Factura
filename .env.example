# Copier vers .env.local et renseigner les valeurs.

# Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serveur uniquement — ne jamais préfixer NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# URL publique de l’app (liens dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — envoi transactional
RESEND_API_KEY=

# Email du compte administrateur (connexion Supabase + accès /admin)
ADMIN_EMAIL=

# Optionnel — rate limiting distribué (https://upstash.com)
# Sans ces variables, un fallback mémoire par instance est utilisé.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tests E2E (Playwright) — compte avec onboarding terminé recommandé
# E2E_ADMIN_EMAIL doit être identique à ADMIN_EMAIL pour /admin
E2E_BASE_URL=http://localhost:3000
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
